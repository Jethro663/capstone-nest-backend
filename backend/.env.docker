# Docker / container environment template.
# This file is intentionally sanitized. Supply real values through Azure secrets
# or your local secret store instead of committing them to the repo.

NODE_ENV=production
PORT=3000

DATABASE_URL=postgresql://postgres:CHANGE_ME_DB_PASSWORD@postgres:5432/capstone
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=5000

REDIS_URL=redis://redis:6379

FRONTEND_URL=http://localhost:3001
NEXT_FRONTEND_URL=http://localhost:3001
MOBILE_URL=http://localhost:8081
BACKEND_PUBLIC_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3001
COOKIE_DOMAIN=
TRUST_PROXY_HOPS=1

JWT_SECRET=CHANGE_ME_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_MIN_32_CHARS
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

OTP_PEPPER=CHANGE_ME_MIN_32_CHARS

EMAIL_SERVICE=gmail
EMAIL_USER=CHANGE_ME_EMAIL
EMAIL_PASSWORD=CHANGE_ME_APP_PASSWORD
EMAIL_FROM=Nexora LMS <no-reply@example.com>

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_TEXT_MODEL=qwen2.5:3b
OLLAMA_VISION_MODEL=gemma3:4b
AI_SERVICE_URL=http://ai-service:8000
AI_SERVICE_TIMEOUT_CHAT_MS=70000
AI_SERVICE_TIMEOUT_EXTRACTION_MS=300000
AI_SERVICE_SHARED_SECRET=CHANGE_ME_INTERNAL_SHARED_SECRET
AI_DEGRADED_ALLOWED=true

OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318
LOKI_HOST=http://loki:3100
