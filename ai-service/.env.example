DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME_DB_PASSWORD@localhost:5432/capstone
# Phase 1 Azure deploy: leave OLLAMA_BASE_URL unset and keep AI_DEGRADED_ALLOWED=true.
# Set this only after Ollama is deployed in Phase 2.
OLLAMA_BASE_URL=
OLLAMA_TEXT_MODEL=qwen2.5:3b
OLLAMA_VISION_MODEL=gemma3:4b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_CHAT_S=60
OLLAMA_TIMEOUT_EXTRACTION_S=240
OLLAMA_KEEP_ALIVE=15m
UPLOAD_DIR=/app/uploads
MAX_RAW_TEXT=50000
LOG_LEVEL=INFO
AI_SERVICE_SHARED_SECRET=CHANGE_ME_INTERNAL_SHARED_SECRET
AI_DEGRADED_ALLOWED=true
