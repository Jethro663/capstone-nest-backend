# Docker compose runtime environment (copy to .env.compose and customize).
# Compose is configured to fail fast if these required variables are missing.

# PostgreSQL bootstrap password (used only when the postgres_data volume is first initialized)
POSTGRES_PASSWORD=NexoraDbPassword123!

# Keep both URLs aligned with POSTGRES_PASSWORD.
# IMPORTANT: URL-encode special characters in passwords (e.g. @ becomes %40).
BACKEND_DATABASE_URL=postgresql://postgres:NexoraDbPassword123%21@postgres:5432/capstone
AI_DATABASE_URL=postgresql+asyncpg://postgres:NexoraDbPassword123%21@postgres:5432/capstone

# Required backend secrets
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_LONG_SECRET_01
JWT_REFRESH_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_LONG_SECRET_02
OTP_PEPPER=CHANGE_ME_AT_LEAST_32_CHARS_LONG_PEPPER_03
AI_SERVICE_SHARED_SECRET=CHANGE_ME_INTERNAL_SHARED_SECRET

# Optional compose overrides
RUN_DB_MIGRATIONS=true
RUN_DB_SEED=false
FRONTEND_PORT=3001
OLLAMA_TEXT_MODEL=qwen2.5:3b
OLLAMA_VISION_MODEL=gemma3:4b
OLLAMA_EMBED_MODEL=nomic-embed-text
